#!/usr/bin/env bash
{{- if ne .chezmoi.os "darwin" }}
exit 0
{{- end }}
set -euo pipefail

info() { printf '\033[1;34m[INFO]\033[0m  %s\n' "$1"; }
ok()   { printf '\033[1;32m[OK]\033[0m    %s\n' "$1"; }
warn() { printf '\033[1;33m[WARN]\033[0m  %s\n' "$1"; }

info "applying macOS defaults"

# Disable Spotlight Cmd+Space so Raycast can use it
defaults write com.apple.symbolichotkeys AppleSymbolicHotKeys -dict-add 64 \
    '{ enabled = 0; value = { parameters = (65535, 49, 1048576); type = standard; }; }'

# Apply hotkey changes immediately
/System/Library/PrivateFrameworks/SystemAdministration.framework/Resources/activateSettings -u

ok "attempted to disable Spotlight Cmd+Space"
warn "if Spotlight still responds: System Settings > Keyboard > Keyboard Shortcuts > Spotlight > uncheck"

# Clean up Dock — keep only Finder (always pinned) and System Settings
info "cleaning Dock (keeping Finder + System Settings only)"
python3 - <<'PYEOF'
import plistlib, os, subprocess

plist_path = os.path.expanduser("~/Library/Preferences/com.apple.dock.plist")
with open(plist_path, "rb") as f:
    dock = plistlib.load(f)

keep = {"システム設定", "System Settings"}
original = dock.get("persistent-apps", [])
dock["persistent-apps"] = [
    app for app in original
    if app.get("tile-data", {}).get("file-label", "") in keep
]
dock.pop("persistent-others", None)

with open(plist_path, "wb") as f:
    plistlib.dump(dock, f)

subprocess.run(["killall", "Dock"])
PYEOF
ok "Dock cleaned"
