# $ZDOTDIR/.zshrc — interactive zsh. PoC mirroring the fish setup.

# --- history -----------------------------------------------------------------
HISTFILE="$XDG_STATE_HOME/zsh/history"
HISTSIZE=200000
SAVEHIST=200000
mkdir -p "${HISTFILE:h}"
setopt EXTENDED_HISTORY SHARE_HISTORY INC_APPEND_HISTORY
setopt HIST_IGNORE_DUPS HIST_IGNORE_ALL_DUPS HIST_IGNORE_SPACE HIST_REDUCE_BLANKS

# --- shell options (fish-like feel) ------------------------------------------
setopt AUTO_CD AUTO_PUSHD PUSHD_IGNORE_DUPS PUSHD_SILENT
setopt INTERACTIVE_COMMENTS NO_BEEP EXTENDED_GLOB

# --- mise (before tools it provides) -----------------------------------------
(( $+commands[mise] )) && eval "$(mise activate zsh)"

# --- plugins -----------------------------------------------------------------
# sheldon drives the full completion load order (see plugins.toml):
#   fpath → compinit → carapace → fzf → fzf-tab → abbr/autopair → autosuggest
#   → fast-syntax-highlighting. compinit/carapace/fzf run *inside* this eval.
(( $+commands[sheldon] )) && eval "$(sheldon source)"

# --- completion styling (compinit already ran inside sheldon, above) ----------
zstyle ':completion:*' menu no                              # fzf-tab replaces the menu
# fish-like fallback: when no completion is defined for a command, parse its
# `--help` output (_gnu_generic). It only runs after _complete yields nothing,
# so carapace/native completions stay preferred. Covers e.g. `claude --<TAB>`.
zstyle ':completion:*' completer _complete _gnu_generic
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'   # case-insensitive
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' group-name ''
zstyle ':completion:*:descriptions' format '%F{244}%d%f'
# fzf-tab tuning: fuzzy picker honors $FZF_DEFAULT_OPTS; dir completions preview.
zstyle ':fzf-tab:*' use-fzf-default-opts yes
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color=always -- $realpath 2>/dev/null'

# --- prompt / navigation -----------------------------------------------------
(( $+commands[starship] )) && eval "$(starship init zsh)"
(( $+commands[zoxide] ))   && eval "$(zoxide init --cmd cd zsh)"

# --- vi mode -----------------------------------------------------------------
bindkey -v
export KEYTIMEOUT=1
bindkey -M viins '^F' autosuggest-accept      # accept grey suggestion
bindkey -M viins '^P' up-line-or-search
bindkey -M viins '^N' down-line-or-search

# Ctrl+Alt+F: fzf file/dir search, insert path at cursor (fish patrickf1 muscle
# memory — _fzf_search_directory). fzf-file-widget is defined by `fzf --zsh`
# (loaded via sheldon above) and otherwise only bound to ^T.
bindkey '^[^F' fzf-file-widget
bindkey -M viins '^[^F' fzf-file-widget

# --- autosuggestion tuning ---------------------------------------------------
ZSH_AUTOSUGGEST_STRATEGY=(history completion)

# --- ghq + fzf repository jump (Ctrl-G), ported from fish-ghq -----------------
ghq-fzf-cd() {
  (( $+commands[ghq] && $+commands[fzf] )) || { zle reset-prompt; return }
  local dir
  dir=$(ghq list --full-path | fzf --query="$BUFFER" ${=GHQ_SELECTOR_OPTS})
  if [[ -n $dir ]]; then
    BUFFER="cd ${(q)dir}"
    zle accept-line
  else
    zle reset-prompt   # cancelled: just redraw, keep what was typed
  fi
}
zle -N ghq-fzf-cd
bindkey '^G' ghq-fzf-cd
bindkey -M viins '^G' ghq-fzf-cd

# --- open: xdg-open / native / container TCP bridge (ported from fish) --------
# Open URL/file: xdg-open on Linux, native `open` on Mac, host bridge in container.
open() {
  if [[ ! -f /.dockerenv ]]; then
    if [[ "$(uname -s)" == Linux ]]; then
      xdg-open "$@"
    else
      command open "$@"
    fi
    return
  fi

  # In container: send to host open-bridge on TCP:12346 (started by devup).
  (( $+commands[socat] )) || { echo "open: socat not found" >&2; return 1 }

  local target=$1
  [[ -n $target ]] || { echo "Usage: open <url|path>" >&2; return 1 }

  if [[ $target == http://* || $target == https://* ]]; then
    printf '%s' "$target" | socat - TCP:127.0.0.1:12346 2>/dev/null
  else
    # Resolve to absolute path and translate container → host path.
    # Container: /home/vscode/.ghq/... → Host: $HOST_HOME/.ghq/...
    local abs_path host_home host_path
    abs_path=$(realpath "$target" 2>/dev/null || echo "$target")
    host_home=${HOST_HOME:-$HOME}
    host_path=${abs_path/#$HOME\/.ghq\//$host_home/.ghq/}
    printf '%s' "$host_path" | socat - TCP:127.0.0.1:12346 2>/dev/null
  fi || { echo "open: failed to connect to host bridge (is devup running?)" >&2; return 1 }
}

# --- aliases & abbreviations -------------------------------------------------
[[ -r "$ZDOTDIR/aliases.zsh" ]] && source "$ZDOTDIR/aliases.zsh"
