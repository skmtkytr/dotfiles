#!/usr/bin/env bash
set -euo pipefail

info() { printf '\033[1;34m[INFO]\033[0m  %s\n' "$1"; }
warn() { printf '\033[1;33m[WARN]\033[0m  %s\n' "$1"; }
err()  { printf '\033[1;31m[ERROR]\033[0m %s\n' "$1" >&2; }

info "preflight checks"

if [ "$(id -u)" -eq 0 ]; then
    err "do not run chezmoi as root"
    echo "  create a user first, then re-run"
    exit 1
fi

{{- if eq .chezmoi.os "linux" }}
if ! command -v sudo >/dev/null 2>&1; then
    err "sudo is required but not installed"
    echo "  install sudo as root first:"
    echo "    apt-get install -y sudo   # Debian/Ubuntu"
    echo "    pacman -Sy --noconfirm sudo  # Arch/CachyOS"
    exit 1
fi
{{- end }}
