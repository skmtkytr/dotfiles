#!/usr/bin/env bash
set -euo pipefail

info() { printf '\033[1;34m[INFO]\033[0m  %s\n' "$1"; }
ok()   { printf '\033[1;32m[OK]\033[0m    %s\n' "$1"; }
warn() { printf '\033[1;33m[WARN]\033[0m  %s\n' "$1"; }

has() { command -v "$1" >/dev/null 2>&1; }

if has mise; then
    ok "mise already installed"
else
    info "installing mise"
    curl -fsSL https://mise.run | sh
fi

# Ensure mise on PATH for this script
export PATH="$HOME/.local/bin:$PATH"

# Use gh token if available to avoid GitHub API rate limit
if [ -z "${GITHUB_TOKEN:-}" ] && has gh && gh auth status &>/dev/null; then
    GITHUB_TOKEN="$(gh auth token)"
    export GITHUB_TOKEN
    info "using gh auth token for GitHub API"
elif [ -z "${GITHUB_TOKEN:-}" ]; then
    warn "no GITHUB_TOKEN set — mise may hit GitHub API rate limits"
    warn "run 'gh auth login' first if you hit limits"
fi

info "installing tools via mise"
mise install -y
