#!/usr/bin/env bash
# 見た目お試し用テーマ詰め合わせ。気に入ったのが決まったら 70 に統合してこのファイルは削除する。
set -euo pipefail

info() { printf '\033[1;34m[INFO]\033[0m  %s\n' "$1"; }
ok()   { printf '\033[1;32m[OK]\033[0m    %s\n' "$1"; }
warn() { printf '\033[1;33m[WARN]\033[0m  %s\n' "$1"; }

has() { command -v "$1" >/dev/null 2>&1; }

{{- if eq .chezmoi.os "linux" }}
{{- $id := .chezmoi.osRelease.id }}
{{- if or (eq $id "arch") (eq $id "manjaro") (eq $id "cachyos") (eq $id "endeavouros") }}

if ! has plasmashell; then
    ok "plasmashell not found, skipping theme buffet"
    exit 0
fi

info "installing KDE theme buffet (try them in System Settings, keep what you like)"

# ---- 公式リポジトリ ----
repo_pkgs=(
    kvantum
    archlinux-wallpaper    # Arch 公式壁紙パック
    deepin-wallpapers      # Deepin 製の高品質壁紙集
    cachyos-wallpapers     # CachyOS 公式壁紙
)
to_install=()
for pkg in "${repo_pkgs[@]}"; do
    if pacman -Qi "$pkg" &>/dev/null; then
        ok "$pkg already installed"
    else
        to_install+=("$pkg")
    fi
done
if [ ${#to_install[@]} -gt 0 ]; then
    info "installing from repo: ${to_install[*]}"
    sudo pacman -S --needed --noconfirm "${to_install[@]}"
fi

# ---- AUR ----
if has paru; then
    aur_helper=paru
elif has yay; then
    aur_helper=yay
else
    warn "no AUR helper, skipping AUR buffet"
    exit 0
fi

aur_pkgs=(
    klassy                            # ⭐ window deco + app style + color schemes
    kvantum-theme-nordic-git          # Qt 用 Nordic
    plasma6-themes-layan-git          # Plasma 6 用 Layan
    plasma6-applets-panel-colorizer   # ⭐ パネル背景を widget 単位で装飾
    tela-icon-theme                   # icon 候補
    colloid-icon-theme-git            # icon 候補
    bibata-cursor-theme               # cursor 候補
    nordic-wallpapers                 # Nord 配色に合う壁紙集
)
aur_to_install=()
for pkg in "${aur_pkgs[@]}"; do
    if pacman -Qi "$pkg" &>/dev/null; then
        ok "$pkg already installed"
    else
        aur_to_install+=("$pkg")
    fi
done
if [ ${#aur_to_install[@]} -gt 0 ]; then
    info "installing from AUR: ${aur_to_install[*]}"
    "$aur_helper" -S --needed --noconfirm "${aur_to_install[@]}" || warn "some AUR builds failed (続行)"
fi

cat <<'EOF'

[NEXT] System Settings から切り替えて試してください:
  - 外観 → グローバルテーマ          : Layan, Klassy など
  - 外観 → アプリケーションスタイル   : Klassy
  - 外観 → ウィンドウ装飾            : Klassy
  - 外観 → 色                       : Klassy 系の color schemes
  - 外観 → アイコン                  : Tela, Colloid-Dark
  - 外観 → カーソル                  : Bibata-Modern-Ice
  - kvantummanager                   : Qt アプリ用テーマ (kvantummanager コマンドで GUI 起動)

[Panel Colorizer の使い方]
  パネル右クリック → ウィジェットを追加 → "Panel Colorizer" を検索して
  パネルに 1 個配置 → 設定でパネル背景・widget の色をカスタマイズ。
  これがパネル見た目改善の主役。

EOF

ok "theme buffet installed"

{{- end }}
{{- end }}
