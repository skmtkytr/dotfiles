#!/usr/bin/env bash
{{- if ne .chezmoi.os "darwin" }}
exit 0
{{- end }}
set -euo pipefail

info() { printf '\033[1;34m[INFO]\033[0m  %s\n' "$1"; }
warn() { printf '\033[1;33m[WARN]\033[0m  %s\n' "$1"; }

brewfile="$HOME/.config/Brewfile"
if [ -f "$brewfile" ]; then
    info "running brew bundle"
    brew bundle --file="$brewfile" || warn "brew bundle had failures (non-fatal, continuing)"
else
    warn "no Brewfile at $brewfile, skipping"
fi
