#!/usr/bin/env bash
set -euo pipefail

info() { printf '\033[1;34m[INFO]\033[0m  %s\n' "$1"; }
ok()   { printf '\033[1;32m[OK]\033[0m    %s\n' "$1"; }
warn() { printf '\033[1;33m[WARN]\033[0m  %s\n' "$1"; }

has() { command -v "$1" >/dev/null 2>&1; }

{{- if eq .chezmoi.os "linux" }}
{{- $id := .chezmoi.osRelease.id }}
{{- if or (eq $id "arch") (eq $id "manjaro") (eq $id "cachyos") (eq $id "endeavouros") }}

# KDE Plasma が無い環境ではスキップ
if ! has plasmashell; then
    ok "plasmashell not found, skipping KDE setup"
    exit 0
fi

info "setting up KDE Plasma 6 visuals"

# ---- 公式リポジトリのパッケージ ----
repo_pkgs=(papirus-icon-theme)
to_install=()
for pkg in "${repo_pkgs[@]}"; do
    if pacman -Qi "$pkg" &>/dev/null; then
        ok "$pkg already installed"
    else
        to_install+=("$pkg")
    fi
done
if [ ${#to_install[@]} -gt 0 ]; then
    info "installing from repo: ${to_install[*]}"
    sudo pacman -S --needed --noconfirm "${to_install[@]}"
fi

# ---- AUR パッケージ ----
if has paru; then
    aur_helper=paru
elif has yay; then
    aur_helper=yay
else
    warn "no AUR helper (paru/yay) found, skipping AUR packages"
    aur_helper=""
fi

if [ -n "$aur_helper" ]; then
    aur_pkgs=(
        kwin-scripts-krohnkite       # 動的タイリング
        plasma6-applets-fokus        # ポモドーロ/集中タイマー
        # kwin-effects-forceblur-git は AUR で頻繁にビルド失敗するため外している
        # 必要なら手動で: paru -S kwin-effects-forceblur-git
    )
    aur_to_install=()
    for pkg in "${aur_pkgs[@]}"; do
        if pacman -Qi "$pkg" &>/dev/null; then
            ok "$pkg already installed"
        else
            aur_to_install+=("$pkg")
        fi
    done
    if [ ${#aur_to_install[@]} -gt 0 ]; then
        info "installing from AUR: ${aur_to_install[*]}"
        "$aur_helper" -S --needed --noconfirm "${aur_to_install[@]}"
    fi
fi

cat <<'EOF'

[NOTE] 手動で済ませるもの:
  1. Wallhaven プラズモイドは AUR に無いので KDE Store から:
       デスクトップ右クリック → ウィジェットを追加 → 新しいウィジェットを取得
       → "Wallhaven" を検索してインストール
  2. プラズモイドのパネル配置 (fokus 等) も手動で 1 回配置する
       (~/.config/plasma-org.kde.plasma.desktop-appletsrc は不安定なので
        chezmoi 管理対象外)
  3. 設定反映は systemsettings からログアウト/再ログイン、または
       kwin の設定変更後 systemsettings で "デスクトップ効果" を一度開閉

EOF

ok "KDE Plasma setup done"

{{- end }}
{{- end }}
