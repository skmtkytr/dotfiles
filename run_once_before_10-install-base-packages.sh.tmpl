#!/usr/bin/env bash
set -euo pipefail

{{- if .features.in_devcontainer }}
# devcontainer は Dockerfile で base packages を導入済み。skip。
exit 0
{{- end }}

info() { printf '\033[1;34m[INFO]\033[0m  %s\n' "$1"; }
ok()   { printf '\033[1;32m[OK]\033[0m    %s\n' "$1"; }
warn() { printf '\033[1;33m[WARN]\033[0m  %s\n' "$1"; }

has() { command -v "$1" >/dev/null 2>&1; }

info "installing base packages"

{{- if eq .chezmoi.os "darwin" }}
# ---- macOS ----
if ! has brew; then
    info "installing Homebrew"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null || /usr/local/bin/brew shellenv 2>/dev/null)"
else
    ok "Homebrew already installed"
fi

pkgs=(git gh socat fish node tmux)
to_install=()
for pkg in "${pkgs[@]}"; do
    if brew list "$pkg" &>/dev/null; then
        ok "$pkg already installed"
    else
        to_install+=("$pkg")
    fi
done
if [ ${#to_install[@]} -gt 0 ]; then
    info "installing: ${to_install[*]}"
    brew install "${to_install[@]}"
fi

{{- else if eq .chezmoi.os "linux" }}
{{- $id := .chezmoi.osRelease.id }}
{{- if or (eq $id "ubuntu") (eq $id "debian") }}
# ---- Debian / Ubuntu ----
need_update=false
if ! has gh; then
    if [ ! -f /usr/share/keyrings/githubcli-archive-keyring.gpg ]; then
        info "adding GitHub CLI repository"
        sudo mkdir -p /usr/share/keyrings
        curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
            | sudo tee /usr/share/keyrings/githubcli-archive-keyring.gpg >/dev/null
        echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
            | sudo tee /etc/apt/sources.list.d/github-cli.list >/dev/null
        need_update=true
    fi
fi
if $need_update; then
    sudo apt-get update
fi

pkgs=(git gh socat fish nodejs npm tmux xdg-ninja)
to_install=()
for pkg in "${pkgs[@]}"; do
    if dpkg -s "$pkg" &>/dev/null; then
        ok "$pkg already installed"
    else
        to_install+=("$pkg")
    fi
done
if [ ${#to_install[@]} -gt 0 ]; then
    info "installing: ${to_install[*]}"
    sudo apt-get install -y "${to_install[@]}"
fi

{{- else if or (eq $id "arch") (eq $id "manjaro") (eq $id "cachyos") (eq $id "endeavouros") }}
# ---- Arch / CachyOS / Manjaro ----
pkgs=(git github-cli socat fish nodejs npm tmux)
if pacman -Si xdg-ninja &>/dev/null; then
    pkgs+=(xdg-ninja)
else
    warn "xdg-ninja not found in repos, skipping"
fi
to_install=()
for pkg in "${pkgs[@]}"; do
    if pacman -Qi "$pkg" &>/dev/null; then
        ok "$pkg already installed"
    else
        to_install+=("$pkg")
    fi
done
if [ ${#to_install[@]} -gt 0 ]; then
    info "installing: ${to_install[*]}"
    sudo pacman -S --needed --noconfirm "${to_install[@]}"
fi

{{- else }}
echo "[ERROR] unsupported Linux distribution: {{ $id }}"
exit 1
{{- end }}
{{- end }}
