#!/usr/bin/env bash
set -euo pipefail

info() { printf '\033[1;34m[INFO]\033[0m  %s\n' "$1"; }
ok()   { printf '\033[1;32m[OK]\033[0m    %s\n' "$1"; }
warn() { printf '\033[1;33m[WARN]\033[0m  %s\n' "$1"; }

has() { command -v "$1" >/dev/null 2>&1; }

if has pbcopy; then
    ok "pbcopy already available"
    exit 0
fi

info "installing pbcopy/pbpaste wrappers (sudo required)"

if has wl-copy; then
    sudo tee /usr/local/bin/pbcopy >/dev/null <<'SH'
#!/bin/sh
wl-copy
SH
    sudo tee /usr/local/bin/pbpaste >/dev/null <<'SH'
#!/bin/sh
wl-paste
SH
elif has xclip; then
    sudo tee /usr/local/bin/pbcopy >/dev/null <<'SH'
#!/bin/sh
xclip -selection clipboard
SH
    sudo tee /usr/local/bin/pbpaste >/dev/null <<'SH'
#!/bin/sh
xclip -selection clipboard -o
SH
else
    warn "neither wl-copy nor xclip found, skipping"
    exit 0
fi

sudo chmod +x /usr/local/bin/pbcopy /usr/local/bin/pbpaste
ok "created pbcopy/pbpaste wrappers"
