#!/usr/bin/env bash
{{- if ne .chezmoi.os "linux" }}
exit 0
{{- end }}
{{- if .features.in_devcontainer }}
exit 0
{{- end }}
set -euo pipefail

info() { printf '\033[1;34m[INFO]\033[0m  %s\n' "$1"; }
ok()   { printf '\033[1;32m[OK]\033[0m    %s\n' "$1"; }
warn() { printf '\033[1;33m[WARN]\033[0m  %s\n' "$1"; }

has() { command -v "$1" >/dev/null 2>&1; }

# ttf-udev-gothic は yuru7/udev-gothic の全バリアント (通常/NF/HS) を
# /usr/share/fonts/TTF に一括インストールする AUR パッケージ。
# https://aur.archlinux.org/packages/ttf-udev-gothic
if pacman -Qi ttf-udev-gothic &>/dev/null; then
    ok "ttf-udev-gothic already installed"
    exit 0
fi

if has yay; then
    info "installing ttf-udev-gothic via yay"
    yay -S --needed --noconfirm ttf-udev-gothic
elif has paru; then
    info "installing ttf-udev-gothic via paru"
    paru -S --needed --noconfirm ttf-udev-gothic
else
    warn "no AUR helper (yay/paru) found — skipping ttf-udev-gothic"
    warn "install manually: https://aur.archlinux.org/packages/ttf-udev-gothic"
fi
